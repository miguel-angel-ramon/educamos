<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<groupId>com.jccm.edu</groupId>
	<artifactId>DeployableProject</artifactId>
	<version>3.7</version>
	<packaging>pom</packaging>
	<name>DeployableProject</name>

	<parent>
		<groupId>com.jccm.edu</groupId>
		<artifactId>NexusProject</artifactId>
		<version>1.3</version>
	</parent>

	<build>

		<plugins>

			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>buildnumber-maven-plugin</artifactId>
				<version>1.0-beta-3</version>
				<configuration>
					<format>{0,date,yyyy-MM-dd HH:mm:ss}</format>
					<items>
						<item>timestamp</item>
					</items>
				</configuration>
				<executions>
					<execution>
						<phase>deploy</phase>
						<goals>
							<goal>create</goal>
						</goals>
					</execution>
				</executions>
			</plugin>

			<plugin>
				<groupId>com.jccm.edu.plugin.maven</groupId>
				<artifactId>MavenMailPlugin</artifactId>
				<version>3.1.2</version>
				<executions>
					<execution>
						<goals>
							<goal>mail</goal>
						</goals>
						<phase>deploy</phase>
					</execution>
				</executions>
				<configuration>
					<!-- Correo -->
					<title>${mailTitle}</title>
					<from>desarrollo.edu@jccm.es</from>
					<toAddresses>
						<item>ias.edu@jccm.es</item>
					</toAddresses>
					<smtpHost>smtp.jccm.es</smtpHost>
					<smtpPort>25</smtpPort>
					<username>ggag18</username>
					<password>e4S414d5_</password>

					<!-- Plantilla -->
					<template>${mailTemplate}</template>
					<servidorApp>${servidorApp}</servidorApp>
					<entorno>${entorno}</entorno>
					<fechaHora>${maven.build.timestamp}</fechaHora>
					<encoding>UTF-8</encoding>
				</configuration>
			</plugin>
		</plugins>
	</build>


	<dependencies>
	</dependencies>

	<profiles>
		<profile>
			<id>serverDeploy</id>
			<activation>
				<activeByDefault>false</activeByDefault>
				<property>
					<name>serverDeploy</name>
					<value>true</value>
				</property>
			</activation>
			<build>
				<plugins>
					<plugin>
						<groupId>org.codehaus.mojo</groupId>
						<artifactId>weblogic-maven-plugin</artifactId>
						<version>2.9.1</version>
						<executions>
							<execution>
								<id>weblogic</id>
								<phase>deploy</phase>
								<goals>	
									<goal>undeploy</goal>
									<goal>deploy</goal>
								</goals>
								<configuration>
									<adminServerHostName>${weblogic.admin.server.address}</adminServerHostName>
									<adminServerPort>${weblogic.admin.server.port}</adminServerPort>
									<userId>${weblogic.admin.user}</userId>
									<password>${weblogic.admin.password}</password>
									<continueOnFailure>true</continueOnFailure>
									<upload>true</upload>
									<remote>true</remote>
									<verbose>true</verbose>
									<debug>true</debug>
									<noExit>true</noExit>
									<name>${weblogic.app.name}</name>
									<targetNames>${weblogic.target.server}</targetNames>
									<artifactPath>${project.build.directory}/${project.artifactId}-${project.version}-${entorno}.${project.packaging}</artifactPath>
								</configuration>
							</execution>
						</executions>
						<dependencies>
							<dependency>
								<groupId>weblogic</groupId>
								<artifactId>weblogic</artifactId>
								<version>11.0</version>
							</dependency>
							<dependency>
								<groupId>weblogic</groupId>
								<artifactId>webservices</artifactId>
								<version>11.0</version>
							</dependency>
							<dependency>
								<groupId>weblogic</groupId>
								<artifactId>deployment</artifactId>
								<version>11.0</version>
							</dependency>
						</dependencies>
					</plugin>
				</plugins>
			</build>
		</profile>


		<profile>
			<id>desarrollo</id>
			<properties>
				<weblogic.admin.server.address>10.18.1.221</weblogic.admin.server.address>
				<weblogic.admin.server.port>7001</weblogic.admin.server.port>
				<weblogic.admin.user>weblogic</weblogic.admin.user>
				<weblogic.admin.password>weblogic17</weblogic.admin.password>
			</properties>
		</profile>
		<profile>
			<id>preproduccion</id>
			<properties>
				<weblogic.admin.server.address>xxxxx</weblogic.admin.server.address>
				<weblogic.admin.server.port>xxxxx</weblogic.admin.server.port>
				<weblogic.admin.user>xxxxx</weblogic.admin.user>
				<weblogic.admin.password>xxxxx</weblogic.admin.password>
			</properties>
		</profile>
		<profile>
			<id>produccion</id>
			<properties>
				<weblogic.admin.server.address>xxxxx</weblogic.admin.server.address>
				<weblogic.admin.server.port>xxxxx</weblogic.admin.server.port>
				<weblogic.admin.user>xxxxx</weblogic.admin.user>
				<weblogic.admin.password>xxxxx</weblogic.admin.password>
			</properties>
		</profile>
		<profile>
			<id>formacion</id>
			<properties>
				<weblogic.admin.server.address>xxxxx</weblogic.admin.server.address>
				<weblogic.admin.server.port>xxxxx</weblogic.admin.server.port>
				<weblogic.admin.user>xxxxx</weblogic.admin.user>
				<weblogic.admin.password>xxxxx</weblogic.admin.password>
			</properties>
		</profile>
	</profiles>

</project>
