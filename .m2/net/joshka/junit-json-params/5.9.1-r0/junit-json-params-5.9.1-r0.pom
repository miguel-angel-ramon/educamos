  <!-- do_not_remove: published-with-gradle-metadata -->
  <modelVersion>4.0.0</modelVersion>
  <groupId>net.joshka</groupId>
  <artifactId>junit-json-params</artifactId>
  <version>5.9.1-r0</version>
  <name>JUnit JSON Params</name>
  <description>JUnit 5 JSON Parameterized Tests library</description>
  <url>http://www.joshka.net/junit-json-params/</url>
  <inceptionYear>2018</inceptionYear>
  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <id>joshka</id>
      <name>Josh McKinney</name>
      <url>http://www.joshka.net</url>
    </developer>
  </developers>
  <scm>
    <connection>scm:git:https://github.com/joshka/junit-json-params.git</connection>
    <developerConnection>scm:git:https://github.com/joshka/junit-json-params.git</developerConnection>
    <url>https://github.com/joshka/junit-json-params/</url>
  </scm>
  <issueManagement>
    <system>Github</system>
    <url>https://github.com/joshka/junit-json-params/issues</url>
  </issueManagement>
  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.junit</groupId>
        <artifactId>junit-bom</artifactId>
        <version>5.9.1</version>
        <type>pom</type>
