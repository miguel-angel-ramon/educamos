<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>es.jccm.edu</groupId>
  <artifactId>eclm-segu-starter</artifactId>
  <version>0.0.4</version>
  
  	<properties>
		<java.version>11</java.version>
	</properties>

	<!-- Proyecto padre con Spring boot de la jccm -->
	<parent>
		<groupId>es.jccm.comun.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>2.1.0</version>
	</parent>
	
	<dependencies>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security</artifactId>
		</dependency>
		
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
		</dependency>
		
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>
		
     	<dependency>
			<groupId>es.jccm.comun.boot</groupId>
			<artifactId>security-oauth2-resource-server-spring-boot-starter</artifactId>
		</dependency>
		
		<!-- log -->
		<dependency>
			<groupId>es.jccm.comun.boot</groupId>
			<artifactId>log-spring-boot-starter</artifactId>
		</dependency>
		
		<!-- test -->
		<dependency>
			<groupId>es.jccm.comun.boot</groupId>
			<artifactId>test-spring-boot-starter</artifactId>
			<scope>test</scope>
			 <exclusions>
		        <exclusion>
		            <groupId>org.junit.vintage</groupId>
		            <artifactId>junit-vintage-engine</artifactId>
		        </exclusion>
		    </exclusions>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-configuration-processor</artifactId>
			<optional>true</optional>
		</dependency>
	</dependencies>
</project>