<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>sadiel</groupId>
    <artifactId>persistencia</artifactId>
    <packaging>jar</packaging>
	
	<parent>
	  <groupId>com.jccm.edu</groupId>
	  <artifactId>NexusProject</artifactId>
	  <version>1.2</version>	
	</parent>
    
    <version>1.0.1-jdk18</version>


    <dependencies>
		<!-- servlet-api, mail, activation ya incluidos con el padre -->
		<dependency>
			<groupId>sadiel</groupId>
			<artifactId>colecciones</artifactId>
			<version>1.0</version>
		</dependency>
		<dependency>
			<groupId>sadiel</groupId>
			<artifactId>reflexion</artifactId>
			<version>1.0</version>
		</dependency>
		<dependency>
			<groupId>sadiel</groupId>
			<artifactId>procesadorcomandos</artifactId>
			<version>1.0</version>
		</dependency>
		<dependency>
			<groupId>sadiel</groupId>
			<artifactId>utils</artifactId>
			<version>1.0</version>
		</dependency>
		<dependency>
			<groupId>commons-digester</groupId>
			<artifactId>commons-digester</artifactId>
			<version>1.6</version>
		</dependency>
		
		
		<!-- dependencias para tests -->
		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
			<version>4.8.2</version>
			<scope>test</scope>
 		</dependency>
    </dependencies>
    
    <properties>
		<java.build.version>1.8</java.build.version>
    	<java.source.version>1.8</java.source.version>
		<maven.compiler.source>1.8</maven.compiler.source>
	    <maven.compiler.target>1.8</maven.compiler.target>
	    <maven.javadoc.skip>true</maven.javadoc.skip>	
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>	        
    </properties>
    
  
</project>