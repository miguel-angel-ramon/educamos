				<textElement textAlignment="Justified" verticalAlignment="Middle" markup="styled">
					<font size="8" isBold="false"/>
					<paragraph leftIndent="45" rightIndent="8" spacingBefore="6" spacingAfter="6"/>
				</textElement>
				<textFieldExpression><![CDATA["<br/>"+"Conocer y comprender plenamente su obligación de guardar absoluto secreto acerca de todos aquellos datos e informaciones de carácter personal o profesional a los que va a tener acceso por el desempeño de su actividad durante su periodo formativo en los centros de trabajo. Dicho deber de secreto subsistirá aún después de haber finalizado su periodo formativo."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="9" y="42" width="178" height="15" uuid="9c215192-3f10-448e-9799-4e75b1c34355">
