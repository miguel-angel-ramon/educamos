				<textElement markup="styled">
					<paragraph firstLineIndent="17"/>
				</textElement>
				<textFieldExpression><![CDATA["b) Autorización para incorporación de formación complementaria al currículo de las enseñanzas, a desarrollar por parte de la empresa que implique la ampliación de la duración de la oferta formativa, con carácter voluntario para el alumnado y , en su caso, certificable al margen de su titulación."]]></textFieldExpression>
