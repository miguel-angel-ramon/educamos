				<textElement markup="styled">
					<paragraph firstLineIndent="17"/>
				</textElement>
				<textFieldExpression><![CDATA["a) Autorización cuando el total de horas de formación Dual entre los dos cursos supera las 400 GB o 580 GM-GS."]]></textFieldExpression>
			</textField>
