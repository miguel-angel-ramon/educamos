package es.jccm.edu.horarios.adapter.in.rest.horarios;

import java.util.List;
import java.util.stream.Collectors;

import org.modelmapper.ModelMapper;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import es.jccm.edu.horarios.adapter.in.rest.horarios.model.AtributosPlanificacionSemanalDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.GrupoActividadDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.HorarioDireccionDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.HorarioGrupoActividadListDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.HorarioListDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.HorarioPersonalDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.ReunionOrganoCentroDto;
import es.jccm.edu.horarios.adapter.in.rest.horarios.model.TotalHorasListDto;
import es.jccm.edu.horarios.application.domain.horarios.HorarioList;
import es.jccm.edu.horarios.application.domain.horarios.HorarioPersonalList;
import es.jccm.edu.horarios.application.domain.horarios.TotalHorasList;
import es.jccm.edu.horarios.application.ports.in.horarios.IHorariosService;
import es.jccm.edu.shared.application.domain.datosUsuarioJwt.DatosUsuarioJwt;
import es.jccm.edu.shared.application.ports.in.datosUsuarioJwt.IDatosUsuarioJwtService;
import es.jccm.edu.shared.configuration.common.Constants;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.media.Content;
import io.swagger.v3.oas.annotations.media.Schema;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;

@RestController
@RequestMapping("${spring.data.rest.base-path:/api}" + "/horarios")
@Tag(name = "Servicio Horarios Escritorio", description = "Servicio para recuperar el módulo de horarios del escritorio")
@CrossOrigin
public class HorariosRestController {
	
	@Autowired
	private IHorariosService horariosService;
	
	@Autowired
	private IDatosUsuarioJwtService datosUsuarioJwtService;
	
	@Autowired
	private ModelMapper modelMapper;
	
	/**
	 * Conectamos con la BBDD de Delphos y sacamos los horarios semanales de un profesor.
	 *
	 * @param String idEmpleado
	 * @param Integer anno
	 * @return List<HorarioGrupoActividadListDto>
	 */
	@PreAuthorize("hasAnyRole('P','PRO','C')")
    @Operation(summary = "Recuperar horarios de un profesor", description = "Este metodo devuelve un objeto List con los horarios de un profesor", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/horarios")
    public ResponseEntity<List<HorarioGrupoActividadListDto>> getHorarios(@RequestHeader(Constants.AUTHORIZATION) String jwt, 
    		@RequestParam("anno") Integer anno, 
    		@RequestParam("codCentro") Long codCentro) {
    	
	    	DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
		List<HorarioGrupoActividadListDto> horariosOut = horariosService.getHorarios(datosUsuario.getIdEmpleadoComunica(), anno, codCentro).stream().map(x -> modelMapper.map(x, HorarioGrupoActividadListDto.class))
				.collect(Collectors.toList());
		
		return new ResponseEntity<>(horariosOut, HttpStatus.OK);
    }

	/**
	 * Conectamos con la BBDD de Delphos y sacamos los horarios semanales de un profesor para un día de la semana.
	 *
	 * @param String idUsuario
	 * @param Integer anno
	 * @param Integer diaSemana
	 * @return List<HorarioListDto>
	 */
	@PreAuthorize("hasAnyRole('P','PRO')")
	@Operation(summary = "Recuperar horarios de un profesor para un dia de la semana", description = "Este metodo devuelve un objeto List con los horarios de un profesor para un día específico",
			responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/horariosByDia")
	public ResponseEntity<List<HorarioListDto>> getHorarios(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("anno") Integer anno, @RequestParam("diaSemana") Integer diaSemana) {

		DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
		List<HorarioList> horariosList = horariosService.getHorariosByDia(datosUsuario.getUsuarioDelphos(), anno, diaSemana);

		List<HorarioListDto> horariosOut = horariosList.stream().map(x -> modelMapper.map(x, HorarioListDto.class)).collect(Collectors.toList());

		return new ResponseEntity<>(horariosOut, HttpStatus.OK);
	}
    
	/**
	 * Conectamos con la BBDD de Delphos y sacamos el total de horas semanales de un profesor.
	 *
	 * @param String idUsuario
	 * @param Integer anno
	 * @return List<TotalHorasListDto>
	 */
	@PreAuthorize("hasAnyRole('P','PRO','C')")
    @Operation(summary = "Recuperar total de horarias de un profesor", description = "Este metodo devuelve un objeto List con las horas de un profesor", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/totalHoras")
    public ResponseEntity<List<TotalHorasListDto>> getTotalHoraras(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("anno") Integer anno) {
    	
    	DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
    	
    	List<TotalHorasList> horariosList = horariosService.getTotalHoras(datosUsuario.getUsuarioDelphos(), anno);
		
		List<TotalHorasListDto> horariosOut = horariosList.stream().map(x -> modelMapper.map(x, TotalHorasListDto.class)).collect(Collectors.toList());
		
		return new ResponseEntity<>(horariosOut, HttpStatus.OK);
    }
    
	/**
	 * Recogemos la planificación semanal del equipo docente
	 *
	 * @param String idUsuario
	 * @param Integer anno
	 * @return List<TotalHorasListDto>
	 */
	@PreAuthorize("hasAnyRole('P','PRO')")
    @Operation(summary = "Recuperar la planificación semanal del equipo docente", description = "Este metodo devuelve un objeto List con las horas de un profesor", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/planificacionSemanal")
    public ResponseEntity<List<AtributosPlanificacionSemanalDto>> getPlanificacionSemanal(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("tomaPos") String tomaPos) {
    	
    	DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
    	
    	List<AtributosPlanificacionSemanalDto> grupoActividadesList = horariosService.getGrupoActividades(datosUsuario.getIdEmpleadoComunica(), tomaPos).stream().map(x -> modelMapper.map(x, AtributosPlanificacionSemanalDto.class)).collect(Collectors.toList());	
		
		
		return new ResponseEntity<>(grupoActividadesList, HttpStatus.OK);
    }

	/**
	 * Recogemos el horario personal
	 *
	 * @param String idUsuario
	 * @param String fechaInicio
	 * @param String fechaFin
	 * @return List<HorarioPersonalDto>
	 */
	@PreAuthorize("hasAnyRole('P','PRO')")
	@Operation(summary = "Recuperar horarios personales", description = "Este metodo devuelve un objeto List con los horarios personales",
			responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/horarioPersonal")
	public ResponseEntity<List<HorarioPersonalDto>> getHorarioPersonal(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("fechaInicio") String fechaInicio, @RequestParam("fechaFin") String fechaFin) {

		DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
        List<HorarioPersonalList> horarioPersonalList = horariosService.getHorarioPersonal(datosUsuario.getXUsuarioComunica(), fechaInicio, fechaFin);

        List<HorarioPersonalDto> horarioPersonalOut = horarioPersonalList.stream().map(horarioPersonal -> modelMapper.map(horarioPersonal, HorarioPersonalDto.class)).collect(Collectors.toList());

		return new ResponseEntity<>(horarioPersonalOut, HttpStatus.OK);
	}
	
	/**
	 * Recogemos el horario direccion
	 *
	 * @param String iEmpleado
	 * @param String ftoma_pos
	 * @return List<HorarioPersonalDto>
	 */
	@PreAuthorize("hasAnyRole('C','RES_CEN')")
	@Operation(summary = "Recuperar horarios de direccion", description = "Este metodo devuelve un objeto List con los horarios de direccion",
			responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/horarioDireccion")
	public ResponseEntity<List<HorarioDireccionDto>> getHorarioDireccion(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("tomaPos") String tomaPos) {

		DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
		List<HorarioDireccionDto> horarioDireccionOut = horariosService.getHorarioDireccion(datosUsuario.getIdEmpleadoDelphos(), tomaPos).stream().map(x -> modelMapper.map(x, HorarioDireccionDto.class)).collect(Collectors.toList());	
		return new ResponseEntity<>(horarioDireccionOut, HttpStatus.OK);
	}
	
	/**
	 * Devolvemos las reuniones de los distintos órganos del centro
	 *
	 * @param Long codCentro
	 * @param String anno
	 * @return List<ReunionOrganoCentroDto>
	 */
	@PreAuthorize("hasAnyRole('C','RES_CEN')")
	@Operation(summary = "Recuperar las reuniones de los órganos del centro", description = "Este metodo devuelve un objeto List con los horarios de direccion",
			responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/reunionesOrganosCentro")
	public ResponseEntity<List<ReunionOrganoCentroDto>> getReunionesOrganosCentro(@RequestParam("codCentro") Long codCentro, @RequestParam("anno") String anno) {

		List<ReunionOrganoCentroDto> reunionesOut = horariosService.getReunionesOrganosCentro(codCentro, anno).stream().map(x -> modelMapper.map(x, ReunionOrganoCentroDto.class)).collect(Collectors.toList());
		
		return new ResponseEntity<>(reunionesOut, HttpStatus.OK);
	}
	
	/**
	 * Conectamos con la BBDD de Delphos y sacamos los grupos actividades de un profesor.
	 *
	 * @param String idEmpleado
	 * @param Integer anno
	 * @return List<GrupoActividadDto>
	 */
    @Operation(summary = "Recuperar grupos de actividad de un profesor", description = "Este metodo devuelve un objeto List con los grupos actividad de un profesor", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/gruposActividadByEmpleadoAnno")
    public ResponseEntity<List<GrupoActividadDto>> getGrupoActividadByEmpleadoAnno(@RequestHeader(Constants.AUTHORIZATION) String jwt, 
    																			   @RequestParam("anno") Integer anno,
    																			   @RequestParam("idCentro") Long idCentro) {
    	
    	DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
		List<GrupoActividadDto> gruposActividadOut = horariosService.getGrupoActividadByEmpleadoAnno(datosUsuario.getIdEmpleadoComunica(), anno, idCentro).stream().map(x -> modelMapper.map(x, GrupoActividadDto.class))
				.collect(Collectors.toList());
		
		return new ResponseEntity<>(gruposActividadOut, HttpStatus.OK);
    }
    
    /**
	 * Conectamos con la BBDD de Delphos y sacamos los grupos actividades comunes de un profesor y un Alumno.
	 *
	 * @param String idEmpleado
	 * @param Long idMatricula
	 * @param Integer anno
	 * @return List<GrupoActividadDto>
	 */
    @Operation(summary = "Recuperar grupos de actividad de un profesor", description = "Este metodo devuelve un objeto List con los grupos actividad de un profesor", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/gruposActividadByEmpleadoAlumnoAnno")
    public ResponseEntity<List<GrupoActividadDto>> gruposActividadByEmpleadoAlumnoAnno(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("idMatricula") Long idMatricula, 
    		@RequestParam("anno") Integer anno) {
    	
    	DatosUsuarioJwt datosUsuario = datosUsuarioJwtService.getDatosUsuarioByJwt(jwt);
		
		List<GrupoActividadDto> gruposActividadOut = horariosService.gruposActividadByEmpleadoAlumnoAnno(datosUsuario.getIdEmpleadoComunica(), idMatricula, anno).stream().map(x -> modelMapper.map(x, GrupoActividadDto.class))
				.collect(Collectors.toList());
		
		return new ResponseEntity<>(gruposActividadOut, HttpStatus.OK);
    }
    
    
    /**
	 * Conectamos con la BBDD de Delphos y sacamos las visitas programadas de un alumno.
	 *
	 * @param Long idMatricula
	 * @return List<VisitasProgramadas>
	 */
    @Operation(summary = "Recuperar visitas programadas de un alumno", description = "Este metodo devuelve un objeto List con las visitas programadas de un alumno", 
    		responses = {@ApiResponse(content = @Content(mediaType = "application/json", schema = @Schema(implementation = ResponseEntity.class)))})
	@ApiResponses(value = { @ApiResponse(responseCode = "200", description = "OK, obtenido correctamente"),
			@ApiResponse(responseCode = "401", description = "No esta autorizado para realizar esta operacion"),
			@ApiResponse(responseCode = "403", description = "Acceso prohibido"),
			@ApiResponse(responseCode = "404", description = "No encontrado") })
	@GetMapping("/visitasProgramadas")
    public ResponseEntity<List<VisitasProgramadasDto>> getVisitasProgramadasPorMatricula(@RequestHeader(Constants.AUTHORIZATION) String jwt, @RequestParam("idMatricula") Long idMatricula) {
    	
		List<VisitasProgramadasDto> visitasProgramadasOut = horariosService.getVisitasProgramadas(idMatricula).stream().map(x -> modelMapper.map(x, VisitasProgramadasDto.class))
				.collect(Collectors.toList());
		
		return new ResponseEntity<>(visitasProgramadasOut, HttpStatus.OK);
    }

}